    <Implementation>
      <ST><![CDATA[//If Soft EStop is pressed, turn off 1027 ~ 1034
IF IO_KUKA.KR_Estop OR NOT IO_control.bEstop OR IO_KUKA.bAlarm_stop = FALSE THEN		
	IO_control.bMove_enable := IO_control.bDrive_off := IO_control.bIO_Act := IO_control.bExt_start:=
	IO_control.bConf_msg := IO_control.bDrive_on := IO_HMI.bMove_enable := IO_HMI.bDrive_off := IO_HMI.bIO_Act := IO_HMI.bExt_start := IO_HMI.bConf_msg := IO_HMI.bDrive_on := FALSE;
END_IF

//Idle monitor all prog byte x running 	
IF IO_KUKA.PLC_I_D1 = 1 AND IO_KUKA.PLC_I_D2 = 0 THEN
	IO_KUKA.Idle := TRUE;
ELSE
	IO_KUKA.Idle := FALSE;
END_IF

//Online monitor T!/EXT mode
IF IO_KUKA.bEXT_mode THEN
	IO_KUKA.KROnline := TRUE;
	//IO.sKUKA_Online_val := '1';
ELSE
	IO_KUKA.KROnline := FALSE;
	//IO.sKUKA_Online_val := '0';
END_IF

//KUKA standby (ext mode) ---pro_act monitoring
IF IO_KUKA.bPro_act THEN
	IO_KUKA.KR_OnStandby := TRUE;
ELSE
	IO_KUKA.KR_OnStandby := FALSE;
END_IF


Timer1(IN:= IO_KUKA.bBin_pickup_InProcess  , PT:= T#5S);

IF IO_KUKA.KR_OnStandby AND IO_Conveyor.bKUKA_Job_Start THEN
	CASE IO.iRackLocation OF
		
		//initilize
		0:	JobRun := FALSE;
			IO_Conveyor.bPickup_Done := FALSE ;
			//IO_Conveyor.bKUKA_Job_Start := FALSE;
		
			
	(*================================ RackA : Pos1 =======================================*)	
		//203
		1:	IF NOT JobRun THEN
				IO_control.bRA_pos1 := TRUE;
			END_IF
		
			IF IO_KUKA.bBin_pickup_InProcess = TRUE THEN
				JobRun := TRUE;
//				IF Timer1.Q THEN
//					bResetOUT := TRUE;
//				END_IF
			END_IF
			
			IF JobRun THEN
				IF IO_KUKA.bBin_pickup_InProcess = FALSE THEN
					IO_Conveyor.bPickup_Done := TRUE;
					bResetOUT := TRUE;
					IF IO_KUKA.bRA_pos1_InProcess = FALSE THEN
						IO_Conveyor.bKUKA_Job_Done := TRUE;
						IO.iRackLocation := 0;
					END_IF
				END_IF
			END_IF
	
	
