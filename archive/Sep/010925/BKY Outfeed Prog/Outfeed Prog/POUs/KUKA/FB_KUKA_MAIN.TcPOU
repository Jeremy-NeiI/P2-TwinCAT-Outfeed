  <POU Name="FB_KUKA_MAIN" Id="{e8ab190c-a631-4882-8a93-6516c2fdb37c}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_KUKA_MAIN
VAR_INPUT
END_VAR
VAR_OUTPUT
