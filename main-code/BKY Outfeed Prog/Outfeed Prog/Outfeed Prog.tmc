 ]]></Comment><Parameter><Name>request</Name><Type Namespace="Recipe_Management.IDatasources">ICustomRequest</Type><BitSize>64</BitSize></Parameter><Parameter><Name>response</Name><Type Namespace="Recipe_Management.IDatasources">ICustomResponse</Type><BitSize>64</BitSize></Parameter><Parameter><Name>result</Name><Type Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</Type><BitSize>32</BitSize></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">ICredentials</Name><BitSize>64</BitSize><ExtendsType>IQueryInterface</ExtendsType></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">ICredentialsProvider</Name><BitSize>64</BitSize><ExtendsType>IQueryInterface</ExtendsType><Method><Name>GetCredentials</Name><Comment><![CDATA[ Must return ERR_OK if called after a successfull |ICredentialsProvider.IsGetCredentialsFinished|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>uxiRequestId</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter><Parameter><Name>credentials</Name><Type Namespace="Recipe_Management.IDatasources">ICredentials</Type><BitSize>64</BitSize><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></Parameter></Method><Method><Name>IsGetCredentialsFinished</Name><Comment><![CDATA[ Will return ERR_OK if the request is finished, ERR_PENDING if it is not yet 
 finished, ERR_DS_RETRYLOGIN if the login should be tried again, another error code in case of an error]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>uxiRequestId</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>LoginFailed</Name><Comment><![CDATA[ Will be called when a login failed due to wrong credentials
 The behaviour of the datasource afterwards depends on the return value. In case of 
 ERR_PENDING, the logincycle will be started again with a call to GetCredentials.
 In all other cases the driver will go to it's error state.]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>uxiRequestId</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter><Parameter><Name>tRetryWaitTime</Name><Type>TIME</Type><BitSize>32</BitSize><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></Parameter></Method><Method><Name>LoginSucceeded</Name><Comment><![CDATA[ Will be called when after a successful login.]]></Comment><Parameter><Name>uxiRequestId</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>StartGetCredentials</Name><Comment><![CDATA[ Will return an id of the question for credentials. This id can be used in 
 the following calls to |ICredentialsProvider.IsGetCredentialsFinished|]]></Comment><ReturnType>ULINT</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>pstDataSource</Name><Type PointerTo="1">STRING(80)</Type><BitSize>64</BitSize></Parameter><Parameter><Name>udiErrorCode</Name><Type Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</Type><BitSize>32</BitSize><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">IDatasource</Name><BitSize>64</BitSize><ExtendsType>IQueryInterface</ExtendsType><Method><Name>__getCustomRequestHandling</Name><ReturnType Namespace="Recipe_Management.IDatasources">ICustomRequestHandling</ReturnType><ReturnBitSize>64</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>EnqueueCustomRequest</Name><Comment><![CDATA[ Enqueues the given request for sending to the connected device the next time this is possible.

 .. note:: It is possible to call this method without holding locks on the datasources (like |IDatasourcesMgr.BeginDataConfiguration|)

 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors| representing the result of the operation.]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>request</Name><Type Namespace="Recipe_Management.IDatasources">ICustomRequest</Type><BitSize>64</BitSize></Parameter><Parameter><Name>finishedCallback</Name><Type Namespace="Recipe_Management.IDatasources">ICustomRequestCallback</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>SetCredentialsProvider</Name><Comment><![CDATA[ Assigns the given credentials provider object to a specific datasource.
 :return: An error code representing the result of the operation]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>provider</Name><Type Namespace="Recipe_Management.IDatasources">ICredentialsProvider</Type><BitSize>64</BitSize></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">IDatasourcesMgr</Name><BitSize>64</BitSize><ExtendsType>IQueryInterface</ExtendsType><Method><Name>ActionRecordDelete</Name><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>record</Name><Type Namespace="Recipe_Management.IDatasources">IDatasourcesActionRecord</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>ActionRecordingGetResult</Name><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>result</Name><Type Namespace="Recipe_Management.IDatasources">IDatasourcesActionRecord</Type><BitSize>64</BitSize><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></Parameter></Method><Method><Name>ActionRecordingStart</Name><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>ActionRecordReplay</Name><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>record</Name><Type Namespace="Recipe_Management.IDatasources">IDatasourcesActionRecord</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>AllItemsOk</Name><Comment><![CDATA[ This method will return ERR_OK when all active items of all datasources have the quality good
 else it will return ERR_DS_BADITEMS.
 It might return ERR_DS_MULTITASKING_LOCKED when it is currently not possible to have access to
 all datasources. In this case the client should call this method again later.]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>BeginDataConfiguration</Name><Comment><![CDATA[ This method locks the concurrent task for monitoring items and allows subsequent accesses 
 to the configuration of the active. To unlock again afterwards, call |IDatasourcesMgr.EndDataConfiguration|

 .. important:: Before calling methods like |IDatasourcesMgr.UseData| or |IDatasourcesMgr.ReleaseData| it is necessary to do this syncronisation to prevent undefined behaviour.

 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>xBlocking</Name><Type>BOOL</Type><BitSize>8</BitSize></Parameter></Method><Method><Name>CreateItemList</Name><Comment><![CDATA[ Creates a new item list that can be used for reading/writing synchronously for example.

 .. important:: Please remark that you have to release the returned object when it is no longer in use by calling |IDatasourcesMgr.DeleteItemList|]]></Comment><ReturnType Namespace="Recipe_Management.IDatasources">IDataItemList</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>udiInitialCapacity</Name><Type>UDINT</Type><BitSize>32</BitSize></Parameter></Method><Method><Name>DeleteItemList</Name><Comment><![CDATA[ Deletes an item list and the items managed therin that was previously created using |IDatasourcesMgr.CreateItemList|
 :return: An error code representing the result of the operation. In case of success, ERR_OK will be returned]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>itemsList</Name><Type Namespace="Recipe_Management.IDatasources">IDataItemList</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>EndDataConfiguration</Name><Comment><![CDATA[ Releases a previously taken lock by |IDatasourcesMgr.BeginDataConfiguration| 
 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>GetDatasource</Name><Comment><![CDATA[ Returns the datasource representing the given object's name. 
 :return: The datasource object or 0 in case there is none with the given name.]]></Comment><ReturnType Namespace="Recipe_Management.IDatasources">IDatasource</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>name</Name><Type>STRING(80)</Type><BitSize>648</BitSize></Parameter></Method><Method><Name>GetItemInfo</Name><ReturnType Namespace="Recipe_Management.IDatasources">IDataItemBase</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>pstSymbol</Name><Type PointerTo="1">STRING(80)</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>ReadItemsSync</Name><Comment><![CDATA[ Reads the given list of items synchronously. 

 .. important:: Please remark that the operation might take quite some time in case many items are contained within the list. For this time, the call is blocking!]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>items</Name><Type Namespace="Recipe_Management.IDatasources">IDataItemList</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>ReleaseData</Name><Comment><![CDATA[ Deactivates the item of the given instance path from monitoring.

 .. note:: The items are reference counted so each call to |IDatasourcesMgr.UseData| requires a matching call to ReleaseData

 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>pstSymbol</Name><Type PointerTo="1">STRING(80)</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>SetCredentialsProvider</Name><Comment><![CDATA[ Assigns the given credentials provider object to all datasources.
 :return: An error code representing the result of the operation]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>provider</Name><Type Namespace="Recipe_Management.IDatasources">ICredentialsProvider</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>UseData</Name><Comment><![CDATA[ Activates the item of the given instance path for monitoring.

 .. note:: The items are reference counted so each call to UseData requires a matching call to |IDatasourcesMgr.ReleaseData|

 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>pstSymbol</Name><Type PointerTo="1">STRING(80)</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>WriteItemsSync</Name><Comment><![CDATA[ Writes the given list of items synchronously. 

 .. important:: Please remark that the operation might take quite some time in case many items are contained within the list. For this time, the call is blocking!]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>items</Name><Type Namespace="Recipe_Management.IDatasources">IDataItemList</Type><BitSize>64</BitSize></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">ItemNameType</Name><BitSize>16</BitSize><BaseType>INT</BaseType><EnumInfo><Text>NormalString</Text><Enum>0</Enum><Comment><![CDATA[ The name represents a POINTER TO a zero terminated STRING of the according length. Take care when derefercing using IEC operators! ]]></Comment></EnumInfo><Properties><Property><Name>qualified_only</Name></Property><Property><Name>strict</Name></Property></Properties></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">ItemName</Name><BitSize>128</BitSize><SubItem><Name>nameType</Name><Type Namespace="Recipe_Management.IDatasources">ItemNameType</Type><BitSize>16</BitSize><BitOffs>0</BitOffs></SubItem><SubItem><Name>nameData</Name><Type PointerTo="1">BYTE</Type><BitSize>64</BitSize><BitOffs>64</BitOffs></SubItem></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">INotificationClient</Name><BitSize>64</BitSize><ExtendsType>IQueryInterface</ExtendsType><Method><Name>ListOperationDone</Name><Comment><![CDATA[ This method will be called when an operation on a list of variables was executed (eg. |IDatasourcesMgr.ReadItemsSync| or |IDatasourcesMgr.WriteItemsSync|) ]]></Comment><Parameter><Name>xWriting</Name><Type>BOOL</Type><BitSize>8</BitSize></Parameter><Parameter><Name>datasourceName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>result</Name><Type Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</Type><BitSize>32</BitSize></Parameter></Method><Method><Name>ListOperationStart</Name><Comment><![CDATA[ This method will be called when an operation on a list of variables will be executed (eg. |IDatasourcesMgr.ReadItemsSync| or |IDatasourcesMgr.WriteItemsSync|) ]]></Comment><Parameter><Name>xWriting</Name><Type>BOOL</Type><BitSize>8</BitSize></Parameter><Parameter><Name>datasourceName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter></Method><Method><Name>ListValueRead</Name><Comment><![CDATA[ This method will be called when a variable was read as part of a list operation (see |INotificationClient.ListOperationStart| or |INotificationClient.ListOperationDone|)]]></Comment><Parameter><Name>remoteName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>pReadValue</Name><Type PointerTo="1">BYTE</Type><BitSize>64</BitSize></Parameter><Parameter><Name>valueType</Name><Type Namespace="Recipe_Management.Collections.IBaseLibrary">TypeClass</Type><BitSize>16</BitSize></Parameter><Parameter><Name>valueSize</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>ListValueWrite</Name><Comment><![CDATA[ This method will be called when a variable will be written as part of a list operation (see |INotificationClient.ListOperationStart| or |INotificationClient.ListOperationDone|)

 .. note:: 
		Please remark that this method will be called before the write operation is sent to the connected device. 
		For being sure about a successful execution the followup call of |INotificationClient.ListOperationDone| should be checked.  ]]></Comment><Parameter><Name>remoteName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>pWriteValue</Name><Type PointerTo="1">BYTE</Type><BitSize>64</BitSize></Parameter><Parameter><Name>valueType</Name><Type Namespace="Recipe_Management.Collections.IBaseLibrary">TypeClass</Type><BitSize>16</BitSize></Parameter><Parameter><Name>valueSize</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>ReadRequestDone</Name><Comment><![CDATA[ This method will be called when a read operation on one or more variables was executed. ]]></Comment><Parameter><Name>datasourceName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>result</Name><Type Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</Type><BitSize>32</BitSize></Parameter></Method><Method><Name>ReadRequestStart</Name><Comment><![CDATA[ This method will be called when a read operation on one or more variables will be executed. ]]></Comment><Parameter><Name>datasourceName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter></Method><Method><Name>SingleValueRead</Name><Comment><![CDATA[ This method will be called when a variable was read from the connected device]]></Comment><Parameter><Name>remoteName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>pReadValue</Name><Type PointerTo="1">BYTE</Type><BitSize>64</BitSize></Parameter><Parameter><Name>valueType</Name><Type Namespace="Recipe_Management.Collections.IBaseLibrary">TypeClass</Type><BitSize>16</BitSize></Parameter><Parameter><Name>valueSize</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>SingleValueWrite</Name><Comment><![CDATA[ This method will be called when a variable will be written to the connected device

 .. note:: 
		Please remark that this method will be called before the write operation is sent to the connected device. 
		For being sure about a successful execution the followup call of |INotificationClient.WriteRequestDone| should be checked.  ]]></Comment><Parameter><Name>remoteName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>pOldValue</Name><Type PointerTo="1">BYTE</Type><BitSize>64</BitSize></Parameter><Parameter><Name>pNewValue</Name><Type PointerTo="1">BYTE</Type><BitSize>64</BitSize></Parameter><Parameter><Name>valueType</Name><Type Namespace="Recipe_Management.Collections.IBaseLibrary">TypeClass</Type><BitSize>16</BitSize></Parameter><Parameter><Name>valueSize</Name><Type>ULINT</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>WriteRequestDone</Name><Comment><![CDATA[ This method will be called when a write operation on one or more variables was executed. ]]></Comment><Parameter><Name>datasourceName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter><Parameter><Name>result</Name><Type Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</Type><BitSize>32</BitSize></Parameter></Method><Method><Name>WriteRequestStart</Name><Comment><![CDATA[ This method will be called when a write operation on one or more variables will be executed. ]]></Comment><Parameter><Name>datasourceName</Name><Type Namespace="Recipe_Management.IDatasources">ItemName</Type><BitSize>128</BitSize></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">PersistantItemListUsage</Name><BitSize>16</BitSize><BaseType>INT</BaseType><EnumInfo><Text>Unspecified</Text><Enum>0</Enum></EnumInfo><EnumInfo><Text>Recipes</Text><Enum>1</Enum><Comment><![CDATA[ The variable list is used for reading or writing recipes. Therefore it is expected that
 the usage details reflect the name of the recipe definition and that all variables of the recipe definition are added
 to the according list.]]></Comment></EnumInfo><Properties><Property><Name>qualified_only</Name></Property><Property><Name>strict</Name></Property></Properties></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">IDataItemListPersistant</Name><BitSize>64</BitSize><ExtendsType Namespace="Recipe_Management.IDatasources">IDataItemList</ExtendsType><Method><Name>__getUsage</Name><ReturnType Namespace="Recipe_Management.IDatasources">PersistantItemListUsage</ReturnType><ReturnBitSize>16</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>__getUsageDetails</Name><ReturnType>WSTRING(80)</ReturnType><ReturnBitSize>1296</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>FinishedAdding</Name><Comment><![CDATA[ This method must be called by users of such a list once the insertion of items (using |IDAtaItemList.CreateAndAdd|)
 is finished. Afterwards the list can be registered within the affected datasource(s). After calling this method it
 is no longer possible to add additional items.
 :return: An error code representing the result of this operation.]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize></Method></DataType><DataType><Name Namespace="Recipe_Management.IDatasources">IDatasourcesMgr2</Name><BitSize>64</BitSize><ExtendsType Namespace="Recipe_Management.IDatasources">IDatasourcesMgr</ExtendsType><Method><Name>__getPersistantItemListCount</Name><ReturnType>INT</ReturnType><ReturnBitSize>16</ReturnBitSize><Properties><Property><Name>property</Name></Property></Properties></Method><Method><Name>AddNotificationClient</Name><Comment><![CDATA[ This method can be used to register an implementation of |INotificationClient| that will be notified about
 operations of the datasources.
 
 .. note:: Please remark that the number of notification clients might be limited so at least if registering several clients the return value should be evaluated.

 .. note:: The registered object can be removed using |IDatasourcesMgr2.RemoveNotificationClient| 

 :return: An error code that signals whether the registration was successful.]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>client</Name><Type Namespace="Recipe_Management.IDatasources">INotificationClient</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>CreatePersistantItemList</Name><Comment><![CDATA[ Creates an item list that will be registered automatically within the affected datasources
 after (re)connections of these datasources. An according list can be used in followup calls to
 |IDatasourcesMgr.ReadItemsSync| or |IDatasourcesMgr.WriteItemsSync|

 .. important:: Having such lists might slow down the connection 
 			   setup because the list has to be registered within the connected device!
  
 .. important:: Using this method and the related ones working on the list requires according locking around using |IDatasourcesMgr2.Lock| and |IDatasourcesMgr2.Unlock|
 
 .. note:: It is not supported to register several lists for the same usecase. 
 
 .. note:: Once the list is no longer necessary, it can be deleted using
			  |IDatasourcesMgr2.DeletePersistantItemList|]]></Comment><ReturnType Namespace="Recipe_Management.IDatasources">IDataItemListPersistant</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>usage</Name><Type Namespace="Recipe_Management.IDatasources">PersistantItemListUsage</Type><BitSize>16</BitSize></Parameter><Parameter><Name>usageDetails</Name><Type>WSTRING(80)</Type><BitSize>1296</BitSize></Parameter><Parameter><Name>udiInitialCapacity</Name><Type>UDINT</Type><BitSize>32</BitSize></Parameter><Parameter><Name>result</Name><Type Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</Type><BitSize>32</BitSize><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></Parameter></Method><Method><Name>DeletePersistantItemList</Name><Comment><![CDATA[ Deletes a formerly created |IDataItemListPersistant|
  
 .. important:: Using this method and the related ones working on the list requires according locking around using |IDatasourcesMgr2.Lock| and |IDatasourcesMgr2.Unlock|
]]></Comment><Parameter><Name>itemsList</Name><Type Namespace="Recipe_Management.IDatasources">IDataItemListPersistant</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>GetPersistantItemList</Name><Comment><![CDATA[ Returns the nth |IDataItemListPersistant| managed by the current instance. Can be used
 for iterating over all lists.
  
 .. important:: Using this method and the related ones working on the list requires according locking around using |IDatasourcesMgr2.Lock| and |IDatasourcesMgr2.Unlock|
]]></Comment><ReturnType Namespace="Recipe_Management.IDatasources">IDataItemListPersistant</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>listNr</Name><Type>INT</Type><BitSize>16</BitSize></Parameter></Method><Method><Name>Lock</Name><Comment><![CDATA[ This method locks the concurrent task for monitoring items and allows subsequent accesses to methods of
 the current instance. To unlock again afterwards, call |IDatasourcesMgr2.Unlock|

 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>xBlocking</Name><Type>BOOL</Type><BitSize>8</BitSize></Parameter></Method><Method><Name>RemoveNotificationClient</Name><Comment><![CDATA[ This method can be called to remove an object that was formerly registered using |IDatasourcesMgr2.AddNotificationClient|
 :return: An error code that signals whether the removal was successful.]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>client</Name><Type Namespace="Recipe_Management.IDatasources">INotificationClient</Type><BitSize>64</BitSize></Parameter></Method><Method><Name>Unlock</Name><Comment><![CDATA[ Releases a previously taken lock by |IDatasourcesMgr2.Lock| 
 :return: Returns a runtime system error code (see CmpErrors.library) or one of |Errors|]]></Comment><ReturnType Namespace="Recipe_Management.SysTypes">RTS_IEC_RESULT</ReturnType><ReturnBitSize>32</ReturnBitSize></Method></DataType><DataType><Name Namespace="Recipe_Management">IRecipeDefinition2</Name><BitSize>64</BitSize><ExtendsType Namespace="Recipe_Management">IRecipeDefinition</ExtendsType><Method><Name>GetRecipeVariableCount</Name><Comment><![CDATA[ Returns the number of recipe variables in the current recipe]]></Comment><ReturnType>DINT</ReturnType><ReturnBitSize>32</ReturnBitSize></Method><Method><Name>GetRecipeVariableName</Name><Comment><![CDATA[ Returns the name of the recipe variable from the corresponding recipe at the given index.
 The variable name will be returned as a pointer to the zero terminated characters in STRING encoding. 
 
 .. note:: For performance reasons this function assumes that CurrentlySelectedRecipe is assigned!]]></Comment><ReturnType PointerTo="1">BYTE</ReturnType><ReturnBitSize>64</ReturnBitSize><Parameter><Name>iVarIndex</Name><Type>DINT</Type><BitSize>32</BitSize></Parameter><Parameter><Name>errorCode</Name><Type>DWORD</Type><BitSize>32</BitSize><Properties><Property><Name>ItemType</Name><Value>Output</Value></Property></Properties></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management">RecipeManCommands</Name><BitSize>256</BitSize><SubItem><Name>_RecipeManager</Name><Type Namespace="Recipe_Management">IRecipeManager</Type><BitSize>64</BitSize><BitOffs>64</BitOffs></SubItem><SubItem><Name>_RecipeDefinition</Name><Type Namespace="Recipe_Management">IRecipeDefinition</Type><BitSize>64</BitSize><BitOffs>128</BitOffs></SubItem><SubItem><Name>_bRecipeManagerSet</Name><Type>BOOL</Type><BitSize>8</BitSize><BitOffs>192</BitOffs></SubItem><SubItem><Name Static="true">s_bRecipeManagerLocked</Name><Type>BOOL</Type><BitSize>8</BitSize><Default><Bool>true</Bool></Default></SubItem><SubItem><Name Static="true">s_sem</Name><Type Namespace="Recipe_Management">RecipeSem</Type><BitSize>128</BitSize></SubItem><Method><Name>SetRecipeManager</Name><Comment><![CDATA[	Sets the recipe manager the function block works with
 
Possible last error values:
ERR_NO_RECIPE_MANAGER_SET, ERR_OK

This method must not be called by the default user because it is set 
implicit in the function prvCheckRecipeManager which is called from all 
methods of the public interface.
]]></Comment><ReturnType>DWORD</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>RecipeManager</Name><Type Namespace="Recipe_Management">IRecipeManager</Type><BitSize>64</BitSize></Parameter><Properties><Property><Name>conditionalshow</Name><Value>visu_coredev</Value></Property></Properties></Method><Method><Name>DeleteRecipe</Name><Comment><![CDATA[ Removes a recipe from the recipe definition

