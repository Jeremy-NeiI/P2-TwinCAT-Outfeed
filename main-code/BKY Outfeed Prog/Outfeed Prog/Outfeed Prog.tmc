]]></Comment><ReturnType>DWORD</ReturnType><ReturnBitSize>32</ReturnBitSize><Parameter><Name>pStrings</Name><Comment><![CDATA[ The strings with the recipe values ]]></Comment><Type>STRING(80)</Type><ArrayInfo PointerTo="1"><LBound>0</LBound><Elements>1</Elements></ArrayInfo><BitSize>64</BitSize></Parameter><Parameter><Name>iSize</Name><Comment><![CDATA[ Size of the string array. ]]></Comment><Type>INT</Type><BitSize>16</BitSize></Parameter><Parameter><Name>iStartIndex</Name><Comment><![CDATA[ Start index. Can be used for a scrolling function (See example)]]></Comment><Type>INT</Type><BitSize>16</BitSize></Parameter></Method><Method><Name>UnregisterEventHandler</Name><ReturnType>BOOL</ReturnType><ReturnBitSize>8</ReturnBitSize><Parameter><Name>handler</Name><Type Namespace="Recipe_Management">IRecipeDefinitionEventHandler</Type><BitSize>64</BitSize></Parameter></Method></DataType><DataType><Name Namespace="Recipe_Management">InfoValues</Name><BitSize>32</BitSize><BaseType>UDINT</BaseType><EnumInfo><Text>NO_INFO</Text><Enum>0</Enum></EnumInfo><EnumInfo><Text>INFO_RECIPE_MANAGER_NOT_ALL_VARIABLES_FOUND</Text><Enum>1</Enum><Comment><![CDATA[ | During load recipe, with the load type "Load matching variables by variable name", some variables 
