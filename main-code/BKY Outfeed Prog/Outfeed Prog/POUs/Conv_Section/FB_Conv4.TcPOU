<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_Conv4" Id="{2a221488-9719-443d-a291-6541d306d3e8}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK PUBLIC FB_Conv4
VAR_INPUT

END_VAR
VAR_OUTPUT
END_VAR
VAR
	bSendID_fired		:	BOOL := TRUE;
	icounter			:	int := 0;
	iSTEP				:	INT := 0;
	Set_Motor			:	BOOL	;
	Reset_Motor			:	BOOL	;
	Reset_Cylinder		:	BOOL	;
	bClear_Bin			:	BOOL := FALSE ;
	rFirescan			:	R_TRIG;
	bScanArmPending : BOOL;   // we're waiting for the scan routine to ack
    tArmTO          : TON;    // wait for bScan_Start to go TRUE
    tRefire         : TON;    // periodic re-fire if no ack
    rStep9Entry     : R_TRIG; // one-shot on entering step 9
	
	
	
	Timer1				:	TON		;
	Timer2				:	TON		;
	Timer3				:	TON		;
	Timer4				:	TON		;
	Timer5				:	TON		;
	Timer6				:	TON		;
	BinID_Matched		:	BOOL	;
	DC_Timer			:	TON;
	
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[rFireScan(CLK := (iSTEP = 9));
rStep9Entry(CLK := (iSTEP = 9));

CASE iSTEP OF 
	
	// ================  CONVEYOR MOTOR INIT  ================ 
	0:	IF IO.bConv_Ready AND IO_control.bEstop THEN
			IO_control.bMotor4 := FALSE;
			iSTEP := iSTEP + 1 ;
		END_IF
	
	// ================  ALIGNMENT CYL INIT  ================ 
	1:	IO_control.bAlCyl_Ext := FALSE ;
		IO_control.bAlCyl_Ret := TRUE ;
		IF IO.bAlCyl1_State_Retract AND NOT IO.bAlCyl1_State_Extend THEN
			IO_Conveyor.bAlCyl_at_Home := TRUE;	 
			iSTEP := iSTEP + 1 ;			
		ELSE
			IO_Conveyor.bAlCyl_at_Home := FALSE;
		END_IF
	
	// ================  END CYL INIT  ================ 		
	2:	Timer1(IN:= IO_Conveyor.bAlCyl_at_Home , PT:=T#0.1S, Q=> Reset_Cylinder);
		IO_control.bEndCyl_Ext S= NOT Reset_Cylinder;
		IO_control.bEndCyl_Ret S= Reset_Cylinder;
		IF IO.bEndCyl1_State_Retract AND NOT IO.bEndCyl1_State_Extend THEN
			IO_Conveyor.bEndCyl_at_Home := TRUE;	
			iSTEP := iSTEP + 1;			
		ELSE
			IO_Conveyor.bEndCyl_at_Home := FALSE;
		END_IF	
	
	// ================  CHECK OPEN STATUS FOR EXIT BUFFER  ================ 
	3:	IF IO_Conveyor.bExit4_IsOpen THEN		
			iSTEP := iSTEP + 1 	;
		END_IF
	
	// ================  MOTOR3 & MOTOR4 TO START WHEN BCONV3_OUT IS ON  ================ 
	4:	IF IO_Conveyor.Conv3_Done THEN
			IO_control.bMotor3 S= IO_Conveyor.Conv3_Done ;
			IO_control.bMotor4 S= IO_Conveyor.Conv3_Done ;
			iSTEP := iSTEP + 1 ;
		END_IF
	
	// ================  MOTOR3 TO STOP IF BCONV4_IN IS ON  ================ 
	5:	IF IO.bConv4_In AND IO.bEndCyl1_State_Retract AND IO.bAlCyl1_State_Retract THEN
			IO_control.bMotor4 S= IO.bConv4_In;
			IO_control.bMotor3 R= IO.bConv4_In;
			IO_Conveyor.Conv3_Done := FALSE ;
			iSTEP := iSTEP + 1 ;
		END_IF
	
	// ================  STOP MOTOR4 IF BIN REACHED BCONV4_OUT  ================ 
	6:	Timer2(IN:= IO.bConv4_Out, PT:=T#0.2S, Q=> Reset_Motor , ET=> );
		IO_control.bMotor4 R= Reset_Motor;
		IF Reset_Motor THEN
			iSTEP := iSTEP + 1 ;
		END_IF
	
	// ================  ALIGN CYL TO EXTEND  ================ 			
	7:	Timer3(IN:= Reset_Motor, PT:=T#0.2S, Q=> IO_Conveyor.Align_To_Work);
		IF IO_Conveyor.Align_To_Work THEN 
			IO.bAlCyl_Ext := TRUE ;
			IO.bAlCyl_Ret := FALSE ;
			IF IO.bAlCyl1_State_Extend AND NOT IO.bAlCyl1_State_Retract THEN
				IO_Conveyor.bAlCyl_at_Work := TRUE ;
				iSTEP := iSTEP + 1 ;
			END_IF	
		END_IF
	
	// ================  ALIGN CYL TO RETRACT  ================ 		
	8:	Timer4(IN:= IO_Conveyor.bAlCyl_at_Work, PT:=T#0.2S, Q=> IO_Conveyor.Align_To_Home);
		IF IO_Conveyor.Align_To_Home THEN 
			IO_control.bAlCyl_Ext := FALSE ;
			IO_control.bAlCyl_Ret := TRUE ;
			IF IO.bAlCyl1_State_Retract AND NOT IO.bAlCyl1_State_Extend THEN
				IO_Conveyor.bAlCyl_at_Work := FALSE;
				iSTEP := iSTEP + 1 ;
			END_IF	
		END_IF
	
	// ================  KEYENCE SCANNER FIRE & GET BIN ID  ================ 		
	9:	
		//IF IO.bConv4_Out AND NOT IO_Conveyor.bKUKA_Job_Start AND NOT IO.bInterrupt_State THEN
		IF rStep9Entry.Q THEN
			bScanArmPending := FALSE;
			tArmTO(IN := FALSE);
			tRefire(IN := FALSE);
			// clear stale frame immediately
			IO.fbClient_QR.fbRx.sPut := 'null';
			IO.sCam_Received_msg     := '';
			icounter := icounter + 1;
		END_IF	
				
		// If the bin presence briefly drops, reset arm state so we can refire cleanly
		IF NOT IO.bConv4_Out THEN
			bScanArmPending := FALSE;
			tArmTO(IN := FALSE);
			tRefire(IN := FALSE);
			IO.bScan_Fire := FALSE;
			RETURN; // stay in step 9 until bin is present again
		END_IF
	
		// If KUKA job started or interrupt, don’t progress; keep step 9 idle-safe
		IF IO_Conveyor.bKUKA_Job_Start OR IO.bInterrupt_State THEN
			bScanArmPending := FALSE;
			tArmTO(IN := FALSE);
			tRefire(IN := FALSE);
			IO.bScan_Fire := FALSE;
			RETURN; // hold in step 9 without doing anything
		END_IF
			
			//keyence scanner connectivity handling
		IF NOT IO.fbClient_QR.bConnected THEN
			DC_Timer(IN := TRUE , PT := T#5S);
			IF DC_Timer.Q THEN
				IO.bReset_ScnrPwr_Cmd := TRUE;
				IF IO.Scn_Reset_Complete THEN	
					DC_Timer(IN := FALSE);
				END_IF
			END_IF
  			bScanArmPending := FALSE;
			tArmTO(IN := FALSE);
			tRefire(IN := FALSE);
			IO.bScan_Fire := FALSE;
			RETURN; // stay in step 9, will try again next cycle
		END_IF
				
		// connected: if not already pending, (re)fire request
		IF NOT bScanArmPending THEN
			// clear stale again right before firing, just to be safe
			IO.fbClient_QR.fbRx.sPut := 'null';
			IO.sCam_Received_msg     := '';
	
			IO.bScan_Fire := TRUE;                 // ask Keyence routine to arm & send
			bScanArmPending := TRUE;
			tArmTO(IN := TRUE, PT := T#2S);        // wait up to 2s for bScan_Start
			tRefire(IN := FALSE);                  // stop periodic retry for now
		END_IF
		
		// got the ack?
		IF IO_Conveyor.bScan_Start THEN
			// we are armed; advance
			IO.bScan_Fire := FALSE;                // consume request
			tArmTO(IN := FALSE);
			tRefire(IN := FALSE);
			iSTEP := 10;
		ELSIF tArmTO.Q THEN
			// no ack within 2s -> schedule periodic retries every 1s
			tArmTO(IN := FALSE);
			tRefire(IN := TRUE, PT := T#1S);
			// when retry timer elapses, allow a re-fire
			IF tRefire.Q THEN
				tRefire(IN := FALSE);
				bScanArmPending := FALSE;          // will re-fire next cycle
			END_IF
		END_IF
//	END_IF
		//END_IF


//				IF NOT IO.fbClient_QR.bConnected THEN
//				DC_Timer(IN := NOT IO.fbClient_QR.bConnected , PT := T#10S);
//				IF DC_Timer.Q THEN
//					IO.bReset_ScnrPwr_Cmd := TRUE;
//					IF IO.Scn_Reset_Complete THEN	
//						DC_Timer(IN := FALSE);
//					END_IF
//				END_IF
//			ELSE
//				//rFireScan(CLK := (iSTEP = 9));
//				IF rFireScan.Q THEN
//					IO.bScan_Fire := TRUE;
//					DC_Timer(IN := FALSE);
//					IO.Scn_Reset_Complete := FALSE;	
//				END_IF
				
//				IF IO_Conveyor.bScan_Start THEN
//					iSTEP := iSTEP + 1 ;
////				IO.bScan_Fire := TRUE;
////				DC_Timer(IN := FALSE);
////				IO.Scn_Reset_Complete := FALSE;
////				iSTEP := iSTEP + 1 ;
//				END_IF
//			END_IF
//		END_IF
	
	// ================  CHECK FOR SCAN COMPLETE OR SCAN FAIL  ================ 
	10: IF IO_Conveyor.bScan_Complete THEN
			iSTEP := iSTEP + 1;
		ELSIF IO_Conveyor.bScan_Failed THEN
			IO_Conveyor.bScan_Start := FALSE;
			IO_Conveyor.bScan_Done := FALSE;
			iSTEP := 20;
//		ELSE
//			iSTEP := 9;
		END_IF	
	
	// ================  SEND BIN ID INFO TO WCS COMMS  ================ 	
	11: IF NOT IO_Conveyor.bReceiving_InProcess AND NOT IO_Conveyor.bKUKA_Job_Start THEN
			IO_Conveyor.bEnd_InProcess := TRUE; 
			
			IF NOT bSendID_fired THEN
				IO.sendID_start := TRUE;
				bSendID_fired := TRUE;
			ELSE
				bSendID_fired := FALSE;
			END_IF
			
			IF IO_Conveyor.bBinID_Sent AND IO_Conveyor.bSendID_Complete THEN
				IO_Conveyor.bScanner_Process_Complete := TRUE;
				IO_Conveyor.bScan_Complete := FALSE;
				iSTEP := iSTEP + 1;
			END_IF
		END_IF
	
	// ================  CHECK FOR RACK LOCATION REPLY  ================ 		
	12:	IF IO_Conveyor.bRack_Loc_Received THEN
			iSTEP := iSTEP + 1;
		END_IF
	
	// ================  END CYL TO EXTEND  ================ 	
	13:	Timer5(IN:= IO.bAlCyl1_State_Retract, PT:=T#0.2S, Q=> IO_Conveyor.bPopup_To_Work);
		IF IO_Conveyor.bPopup_To_Work THEN
			IO_control.bEndCyl_Ext := TRUE ;
			IO_control.bEndCyl_Ret := FALSE ;
			IF IO.bEndCyl1_State_Extend AND IO.bConv4_Out AND NOT IO.bEndCyl1_State_Retract THEN
				IO_Conveyor.Bin_At_Exit_4 := TRUE ;
				IO_Conveyor.bKUKA_Job_Start := TRUE;
				iSTEP := iSTEP + 1;
			END_IF	
		END_IF
	
	// ================  CHECK FOR KUKA PICKUP DONE  ================ 
	14: //IO_Conveyor.bKUKA_Job_Start := TRUE;
		IF IO_Conveyor.bPickup_Done AND IO_Conveyor.bKUKA_Job_Start THEN
				Timer6(IN:= IO_Conveyor.bPickup_Done, PT:=T#0.5S, Q=> IO_Conveyor.bPopup_To_Home , ET=> );
				IO_Conveyor.bRack_Loc_Received := FALSE;
				IF IO_Conveyor.bPopup_To_Home THEN 
					IO_control.bEndCyl_Ext := FALSE ;
					IO_control.bEndCyl_Ret := TRUE ;
					iSTEP := iSTEP + 1;
				END_IF
		END_IF
	
	// ================  CHECK FOR CYL RETRACT ONLY WHEN BIN IS NOT PRESENT  ================ 
	15: IF IO.bEndCyl1_State_Retract AND NOT IO.bEndCyl1_State_Extend  AND NOT IO.bConv4_Out THEN
			IO_Conveyor.Conv4_Done := TRUE ;
			IO_Conveyor.Bin_At_Exit_4 := FALSE ;
			IO_Conveyor.bRack_Loc_Received := FALSE;
			iSTEP := 0 ;
		END_IF	
	
	// ================  IF SCAMMING FAILED TO GET BIN ID  ================ 
	20: IF IO_Conveyor.bScan_Failed THEN
			//turn scanner off
			IO.sCam_msg := IO.QR_Read_OFF;
			IO.fbClient_QR.fbTx.AddTail( sPut := IO.sCam_msg);
			iSTEP := iSTEP +1;
		END_IF
	
	21: IF IO.bRe_run_Fire THEN
			iSTEP := iSTEP +1;
		END_IF
		
	22:	IO.fbClient_QR.fbRx.sPut := 'null';
		IO_Conveyor.bScan_Failed := FALSE;
		IO.bRe_run_Fire := FALSE;
		IO.bScan_Fire := FALSE;
   		IO.bRe_run_Fire := FALSE;
		iSTEP := 9;

END_CASE

IF IO_control.bReset AND IO.bManualMode THEN
	IO_Conveyor.bAlCyl_at_Home := FALSE;
	IO_Conveyor.bEndCyl_at_Home := FALSE;
	IO_Conveyor.bAlCyl_at_Work := FALSE;
	IO_Conveyor.bScan_Start := FALSE;
	IO_Conveyor.bScan_Done := FALSE;
	IO.bScan_Fire := FALSE;
	iSTEP := 0 ;
END_IF
	
]]></ST>
    </Implementation>
