      <LineId Id="25" Count="0" />
      <LineId Id="22" Count="0" />
      <LineId Id="28" Count="1" />
      <LineId Id="34" Count="0" />
      <LineId Id="41" Count="7" />
      <LineId Id="33" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>